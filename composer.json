{
    "name" : "oihana/php-openedge" ,
    "type" : "library" ,
    "description" : "Composable PHP toolkit for the Progress OpenEdge SQL database via ODBC. Bundles a functional query builder (predicates, casts, string/numeric/date functions, CASE expressions), document/edge models composed by traits, PSR-7 CRUD controllers, and Symfony Console commands. Built for read-heavy ERP integrations." ,
    "keywords" : [
        "php" ,
        "openedge" ,
        "progress" ,
        "odbc" ,
        "pdo" ,
        "sql" ,
        "query-builder" ,
        "erp" ,
        "psr-7" ,
        "documents" ,
        "casbin"
    ] ,
    "homepage" : "https://github.com/BcommeBois/oihana-php-openedge" ,
    "license" : "MPL-2.0" ,
    "authors" : [
        {
            "name"     : "Marc Alcaraz" ,
            "email"    : "marc@ooop.fr" ,
            "homepage" : "https://www.ooop.fr" ,
            "role"     : "Project Founder, Lead Developer."
        }
    ] ,
    "support" : {
        "email"  : "marc@ooop.fr" ,
        "issues" : "https://github.com/BcommeBois/oihana-php-openedge/issues" ,
        "source" : "https://github.com/BcommeBois/oihana-php-openedge"
    } ,
    "scripts" : {
        "doc"  : "rm -rf docs && mkdir docs && cp -r assets docs/assets && ./vendor/bin/phpdoc -c phpdoc.xml -v" ,
        "test" : "./vendor/bin/phpunit"
    } ,
